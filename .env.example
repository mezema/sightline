DATABASE_URL=postgres://sightline:sightline@localhost:5436/sightline
SIGHTLINE_APP_URL=http://localhost:3000

# Default local development keeps the deterministic fake workflow.
ANALYZER_PROVIDER=fake

# Clerk auth. When these are unset, local development uses the seeded dev owner.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Real analyzer mode.
# ANALYZER_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# SIGHTLINE_IMAGE_WIDTH=256
# SIGHTLINE_IMAGE_HEIGHT=180

# Durable background jobs. Keep local queue unless Trigger.dev is running/deployed.
# SIGHTLINE_JOB_QUEUE=trigger
# TRIGGER_SECRET_KEY=
# TRIGGER_PROJECT_ID=

# Cloudflare R2 private storage.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Use "server" locally if the R2 bucket CORS policy has not been applied yet.
# Production should use direct uploads.
# SIGHTLINE_UPLOAD_MODE=direct
# CLOUDFLARE_API_TOKEN=
