{
  "rules": [
    {
      "id": "sightline-browser-uploads",
      "allowed": {
        "origins": ["http://localhost:3000", "http://127.0.0.1:3000"],
        "methods": ["PUT", "GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
